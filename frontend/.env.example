# --- Frontend (Vite) ---
# Mettre false pour utiliser le vrai backend, true pour le mode démo hors-ligne.
VITE_USE_MOCK=true

# Base des appels API (passe par le proxy Vite en dev).
VITE_API_BASE_URL=/api/v1

# Cible du proxy Vite vers le backend (dev).
VITE_PROXY_TARGET=http://localhost:8000

# Keycloak (login Resource Owner Password en dev)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=ydays
VITE_KEYCLOAK_CLIENT_ID=frontend-app
