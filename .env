# ==========================================
# YDAYS 2026 - Environment Variables (Example)
# ==========================================

# --- PostgreSQL ---
POSTGRES_USER=ydays_admin
POSTGRES_PASSWORD=ydays_secret_pass
POSTGRES_DB=ydays_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
# SQLAlchemy Database URL used by FastAPI
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# --- Keycloak ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
# The host Keycloak is accessible at (use localhost for local dev)
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=ydays-realm
KEYCLOAK_CLIENT_ID=ydays-backend-client
# JWT Config
JWT_ALGORITHM=RS256
JWT_AUDIENCE=account

# --- MinIO ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET_NAME=ydays-hr-documents

# --- ChromaDB ---
CHROMA_DB_HOST=chromadb
CHROMA_DB_PORT=8000

# --- FastAPI ---
API_V1_STR=/api/v1
PROJECT_NAME="YDAYS 2026 HR AI Platform"
DEBUG=True

APP_NAME=YDAYS_IA_RH
APP_ENV=dev

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL_RH=mistralai/mistral-small-24b-instruct-2501
OPENROUTER_MODEL_GENERAL=mistralai/mistral-small-24b-instruct-2501
OPENROUTER_MODEL_CLASSIFIER=mistralai/mistral-small-24b-instruct-2501
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=YDAYS IA RH

CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION_NAME=rh_documents
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

RAG_TOP_K=5
RAG_MIN_CONFIDENCE=0.60

ENABLE_AUDIT_LOGS=true
ENABLE_SECURITY_FILTER=true
ENABLE_RBAC=true
