# --- Base de données ---
DATABASE_URL=sqlite:///./synapse.db
DB_SEED=true

# --- Keycloak ---
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ydays
KEYCLOAK_CLIENT_ID=frontend-app
AUTH_VERIFY_SIGNATURE=false

# --- Assistant IA (OpenRouter) ---
# Coller ICI la vraie clé sk-or-v1-... (NE PAS committer ce fichier).
# Laisser vide => mode démo (réponses simulées, sans réseau).
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Modèle de l'agent (réponses) et modèle juge (évaluation).
# Variantes gratuites possibles : google/gemma-4-31b-it:free, qwen/qwen3.6-27b:free
AGENT_MODEL=google/gemma-4-31b-it
JUDGE_MODEL=qwen/qwen3.6-27b
AI_MAX_TOKENS=1024
OPENROUTER_SITE_URL=http://localhost:5173
OPENROUTER_APP_NAME=Synapse Digital


# --- RAG (vector store + embeddings) ---
RAG_ENABLED=true
RAG_TOP_K=4
# Seuil de similarite : ~0.05 pour le backend hashing, ~0.30 pour sentence-transformers
RAG_MIN_SCORE=0.05
# auto -> ChromaDB si installe, sinon memoire | valeurs: auto|chroma|memory
RAG_VECTOR_BACKEND=auto
# auto -> sentence-transformers si installe, sinon OpenRouter si cle, sinon hashing
RAG_EMBED_BACKEND=auto
CHROMA_PATH=./chroma
EMBED_MODEL_ST=sentence-transformers/all-MiniLM-L6-v2
EMBED_MODEL_OR=openai/text-embedding-3-small

# --- CORS (serveur Vite) ---
CORS_ORIGINS=http://localhost:5173
